# http:/purl.org/scimin-crm-mwf/Operation
<http:/purl.org/scimin-crm-mwf/Operation> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<http:/purl.org/scimin-crm-mwf/Operation> <http://www.w3.org/2000/01/rdf-schema#comment> "It is an Activity" .
# 
# http:/purl.org/scimin-crm-mwf/Ore
<http:/purl.org/scimin-crm-mwf/Ore> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<http:/purl.org/scimin-crm-mwf/Ore> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http:/purl.org/scimin-crm-mwf/Mineral> .
<http:/purl.org/scimin-crm-mwf/Ore> <http://www.w3.org/2000/01/rdf-schema#comment> "An ore is a mineral or rock containing metal ore mineral concentrations that can be economically extracted. The ore is  the source from where the metal or other mineral substances are extracted"@en .
# 
# http:/purl.org/scimin-crm-mwf/PPEProtocol
<http:/purl.org/scimin-crm-mwf/PPEProtocol> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<http:/purl.org/scimin-crm-mwf/PPEProtocol> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http:/purl.org/scimin-crm-mwf/Protocol> .
<http:/purl.org/scimin-crm-mwf/PPEProtocol> <http://www.w3.org/2002/07/owl#disjointWith> <http:/purl.org/scimin-crm-mwf/SafetyProtocol> .
<http:/purl.org/scimin-crm-mwf/PPEProtocol> <http://www.w3.org/2000/01/rdf-schema#comment> "Personal Protective Equipment (PPE), used to safeguard workers from exposure to hazardous substances" .
# 
# http:/purl.org/scimin-crm-mwf/Permit
<http:/purl.org/scimin-crm-mwf/Permit> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<http:/purl.org/scimin-crm-mwf/Permit> <http://www.w3.org/2000/01/rdf-schema#comment> "License or consent to do or say something." .
# 
# http:/purl.org/scimin-crm-mwf/PetrologicalAnalysisOperation
<http:/purl.org/scimin-crm-mwf/PetrologicalAnalysisOperation> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
<http:/purl.org/scimin-crm-mwf/PetrologicalAnalysisOperation> <http://www.w3.org/2000/01/rdf-schema#subClassOf> <http:/purl.org/scimin-crm-mwf/LaboratoryAnalysisOperation> .
# 
# http:/purl.org/scimin-crm-mwf/PhysicalAnalysis
<http:/purl.org/scimin-crm-mwf/PhysicalAnalysis> <http://www.w3.org/1999/02/22-rdf-syntax-ns#type> <http://www.w3.org/2002/07/owl#Class> .
