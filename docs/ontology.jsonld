  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Any material that poses a threat to human health or the environment due to its chemical or physical properties"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/HealthImpact",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Documented or potential effects of recovery operations on the health of nearby populations"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/Impact"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/HealthRisk",
