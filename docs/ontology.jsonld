}, {
  "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/GrindingOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "METSO Handbook : Grinding is the stage of size reduction (wet or dry) where the liberation size for individual minerals can be reached. By further size reduction filler (mineral powder) is produced."
  }, {
    "@language" : "en",
    "@value" : "MWEI BREF : Comminution process yielding a fine product (< 1 mm), where size reduction \nis accomplished by abrasion and impact and sometimes supported by the free \nmotion of unconnected media such as rods, balls and pebbles."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/MineralProcessingOperation"
  } ]
}, {
