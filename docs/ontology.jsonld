  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "MWEI BREF : The direct or indirect introduction, as a result of human activity, of \nsubstances, vibrations, heat or noise into air, water or land which may be \nharmful to human health or the quality of the environment, result in damage \nto material property, or impair or interfere with amenities and other legitimate \nuses of the environment."
  }, {
    "@value" : "Any change caused by a proposed activity to land, water, air and biodiversity"
  }, {
    "@value" : "The environmental effects identified and quantified through LCA in relation to mining operations."
  } ],
