  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/SpeciesAssessmentMethod"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/HabitatsImpact",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "The impact of a proposed activity on the extent and condition of habitats"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/BiodiversityImpact"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/HabitatsManagementGuideline",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Guideline defining how to decide on management measures that create the best possible positive outcome for habitat extent and condition"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/Guidelines"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/HazardousSubstance",
