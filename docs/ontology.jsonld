}, {
  "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/CrushingAndScreeningOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "METSO Handbook : Crushing and screening is the first controlled size reduction stage in the process. This is the main process in aggregate  production and a preparation process for further size reduction."
  }, {
    "@language" : "en",
    "@value" : "MWEI BREF : Comminution process that reduces the particle size of ore to such a level that  grinding can be carried out. Usually, this is accomplished by compression of  ore against rigid surfaces, or by impact against surfaces in a rigidly constrained motion path."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#isDefinedBy" : [ {
    "@language" : "en",
    "@value" : "MWEI BREF : Screening Separating material into size fractions."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/MineralProcessingOperation"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/DesktopProximityGuideline",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Guideline defining the scope and purpose of a desktop proximity analysis, and how to use its output"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/Guidelines"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/DewateringOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "MWEI BREF : Process of removing water from an underground mine or open pit, or from the  surrounding rock or non-lithified area. The term is also commonly used for the reduction of water content in concentrates, extractive waste from mineral  processing and treatment sludge. In hydrocarbon extraction, dewatering may  refer to removing water from water-based drilling muds and cuttings."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/MineralProcessingOperation"
  } ]
}, {
  "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/DrillingOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "METSO Handbook : Drilling (and blasting) is the technology of achieving primary fragmentation of “in situ” minerals. This is the starting point for  most mineral processes with the exception of natural minerals in the form of sand and gravel."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/MineralProcessingOperation"
  } ]
