  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/Guidelines"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/BiodiversityAssessmentMethod",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/AssessmentMethod"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/BiodiversityImpact",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Any change caused by a proposed activity to species and habitats, ecosystems and landscapes"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/EnvironmentalImpact"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/BlastingOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/MineralProcessingOperation"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/ChemicalAnalysisOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "process of determining the chemical composition of a substance using a range of methods and instruments to identify, characterize, and quantify its components"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/LaboratoryAnalysisOperation"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/CommunityEngagementStrategy",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/CompactionOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Compaction of minerals includes the technologies for moving and densifying minerals by vibration, impaction and pressure, mainly used in construction applications.\n\nMWEI BREF : Process resulting in a reduction in volume. The change typically results from externally applied loads, creating tighter packing of the solid particles. In fine soils in particular, this requires an egress of pore water. Greater compaction often results in increased consolidation"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/MineralProcessingOperation"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/ContainmentSystem",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/ControlMeasure"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/ControlMeasure",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Techniques or technologies used to reduce exposure to hazardous substances, such as water sprays or enclosures"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/CountryLevel",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/Level"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Covers",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/ContainmentSystem"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/Liners"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/CrushingAndScreeningOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Crushing and screening is the first controlled size reduction stage in the process. This is the main process in aggregate  production and a preparation process for further size reduction.\n\nMWEI BREF : Comminution process that reduces the particle size of ore to such a level that  grinding can be carried out. Usually, this is accomplished by compression of  ore against rigid surfaces, or by impact against surfaces in a rigidly constrained motion path.\n\nMWEI BREF : Screening Separating material into size fractions."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/MineralProcessingOperation"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/CrushingMillingEquipment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "What machinery/equipment is suitable to achieve desired particle size."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/Equipment"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/DesktopProximityGuideline",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Guideline defining the scope and purpose of a desktop proximity analysis, and how to use its output"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/Guidelines"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/DewateringOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "MWEI BREF : Process of removing water from an underground mine or open pit, or from the  surrounding rock or non-lithified area. The term is also commonly used for the reduction of water content in concentrates, extractive waste from mineral  processing and treatment sludge. In hydrocarbon extraction, dewatering may  refer to removing water from water-based drilling muds and cuttings."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/MineralProcessingOperation"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/DrillingOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Drilling (and blasting) is the technology of achieving primary fragmentation of “in situ” minerals. This is the starting point for  most mineral processes with the exception of natural minerals in the form of sand and gravel."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
