  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/ExplorationOperation"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/LandImpact",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/EnvironmentalImpact"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/LeachingOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "MWEI BREF : Extraction of soluble components from raw materials by the action of a percolating liquid (e.g. water). For example, gold can be extracted by heap leaching of a porous ore, or pulverised extractive waste from mineral processing. Other methods are tank leaching of ore, concentrates or extractive waste from mineral processing and in-situ leaching. Leaching may also be an unwanted process leading to polluted drainage (see \"leachate\"). Bio-leaching is a particular form of leaching involving living organisms"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/MineralProcessingOperation"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/LegalRestriction",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Laws and regulations that may limit or condition recovery operations"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/Restriction"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Level",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/LightPollution",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/EnvironmentalImpact"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Liners",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/ContainmentSystem"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/LoadingOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/MaterialHandlingOperation"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/LocalLevel",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/Level"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Location",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "General information, location of deposit, extisting infrastructure issues, map of location.\n\nhttps://www.wikidata.org/wiki/Property:P625\nhttps://www.wikidata.org/wiki/Q142"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MacroscopicCharacteristics",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/core:Characteristics"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Material",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "INSPIRE: EarthMaterial is an abstract class which holds a description of a naturally occurring substance in the Earth. Earth Material represents material composition or substance, and is thus independent of quantity or location."
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MaterialHandlingOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Materials handling includes the technologies for moving the process flow (dry) forward by loading, transportation, storage  and feeding"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/Operation"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MaterialMeasurement",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/Measurement"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Measurement",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Metal",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/Mineral"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Methodology",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Metric",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Metrics that translate collected data into representative information that can be used in decision-making"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MicroscopicCharacteristics",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/core:Characteristics"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MillingOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "MWEI BREF : Operation during which ore is treated for the recovery and/or concentration of valuable minerals prior to shipment to a smelter or refinery. Milling\nprocesses include crushing, grinding, screening, concentration and dewatering. At a coal mine, the mill is referred to as a wash plant, tipple or cleaner"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/MineralProcessingOperation"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Mine",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "MWEI BREF : Area under the control of an operator where mining occurs (see \"mining\"), including common related infrastructure and waste management activities.\n\nINSPIRE: An excavation carried out for the extraction of mineral deposits."
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Mineral",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Mineral is a natural inorganic substance precisely defined  according to its physical and chemical characteristics.\n\nINSPIRE: Mineral is defined as any naturally occurring inorganic element or compound having a periodically repeating arrangement of atoms and a characteristic chemical composition or range of compositions, resulting in distinctive physical properties."
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MineralMeasurement",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/Measurement"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MineralProcessingOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "MWEI BREF : Mineral processing (also beneficiation or benefication, ore dressing, mineral dressing, milling) \nProcesses to produce marketable mineral products (e.g. concentrates) from mineral resources. This is usually carried out on the mine or quarry site, the plant being referred to as the mineral processing plant (mill or concentrator). .The essential purpose is to reduce the bulk of the ore, which must be transported to and processed by subsequent processes (e.g. smelting), by using methods to separate the valuable (desired) mineral(s) from the gangue. \nThe marketable product of this is called concentrate, the remaining material is called extractive waste from mineral processing (e.g. tailings).\nMineral processing includes various procedures that rely on the mineral's physical characteristics (i.e. particle size, density, magnetic properties, colour) or physico-chemical properties (surface tension, hydrophobicity, wettability)."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/Operation"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MineralogicalAnalysis",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MineralogicalAnalysisOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Determines the types and relative amounts of minerals within a material, providing insights into its composition, properties, and formation conditions"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/LaboratoryAnalysisOperation"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MineralogicalCharacteristics",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/core:Characteristics"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MiningLCA",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "LCA in mining is a systematic method for identifying, quantifying, and evaluating the environmental impacts associated with the entire life cycle of mining-related processes and products, from exploration and extraction to processing, transportation, use, and end-of-life management."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/LCA"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MiningWaste",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "MWEI BREF : Waste resulting from the prospecting, extraction, treatment and storage of mineral resources and the working of quarries.\n\nMining activity exploits a mineral deposit, obtaining a concentrate (mineral object of the activity) and waste."
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MiningWasteFacility",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "A mining waste facility is a designated site or structure used to store extractive waste (includes materials like waste rock and tailings from mining and mineral processing operations).\n\nMWEI BREF : Any area under the responsibility of an operator where extractive waste is  handled, treated, accumulated or deposited whether in a solid or liquid state or  in solution or suspension. This includes, but is not limited to, Extractive \nWaste Facilities, excavation voids where extractive waste is placed back, and  areas for temporary storage of extractive waste.\n\nMining Waste (INSPIRE Model)\nMining waste can be defined as a part of the materials that result from the exploration, mining and processing of substances governed by legislation on mines and quarries."
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MiningWasteMeasurement",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/Measurement"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MitigationEnvironmentalImpactProcedure",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/MitigationProcedure"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/SocialAcceptanceProcedure"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MitigationProcedure",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/Procedure"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MonitoringRequirement",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MorphologicalCharacteristics",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/core:Characteristics"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/MulticableEquipment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/ExplorationEquipment"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/NACECode",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/NoisePollution",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/EnvironmentalImpact"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Operation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "It is an Activity"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Ore",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "An ore is a mineral or rock containing metal ore mineral concentrations that can be economically extracted. The ore is  the source from where the metal or other mineral substances are extracted"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/Mineral"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/PPEProtocol",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Personal Protective Equipment (PPE), used to safeguard workers from exposure to hazardous substances"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/Protocol"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/SafetyProtocol"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Permit",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "License or consent to do or say something."
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/PetrologicalAnalysisOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/LaboratoryAnalysisOperation"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/PhysicalAnalysis",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/PhysicalAndEnvironmentalTestingOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/LaboratoryAnalysisOperation"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Preparation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/SamplingPlan"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/PrimaryCrushingOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "MWEI BREF : Process of reducing ore into smaller fragments to prepare it for further  processing and/or so that it can be transported to the processing plant. In \nunderground mines, the primary crusher is often located underground or at the \nentrance to the processing plant."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/MineralProcessingOperation"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Procedure",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/ProcessingEquipment",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "What machinery/equipment is suitable to achieve desired particle size."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/Equipment"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/ProcessingPlant",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "MWEI BREF : Facility where mineral processing is carried out.\nMineral processing (also beneficiation or benefication, ore dressing, mineral dressing, milling) \nProcesses to produce marketable mineral products (e.g. concentrates) from mineral resources. This is usually carried out on the mine or quarry site, the plant being referred to as the mineral processing plant (mill or concentrator). The essential purpose is to reduce the bulk of the ore, which must be transported to and processed by subsequent processes (e.g. smelting), by using methods to separate the valuable (desired) mineral(s) from the gangue. \nThe marketable product of this is called concentrate, the remaining material is called extractive waste from mineral processing (e.g. tailings).\nMineral processing includes various procedures that rely on the mineral's physical characteristics (i.e. particle size, density, magnetic properties, colour) or physico-chemical properties (surface tension, hydrophobicity, wettability)."
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Protocol",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/ControlMeasure"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/PyroProcessingOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@language" : "en",
    "@value" : "Pyro processing includes the technologies for upgrading of the mineral fractions by drying, calcining or sintering."
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/MineralProcessingOperation"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/QualityAssuranceAndControlOperation",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/LaboratoryAnalysisOperation"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Reagent",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "A substance or compound added to a system to cause a chemical reaction or test for the presence of another substance"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/ReclamationActivity",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
