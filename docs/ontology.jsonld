}, {
  "@id" : "http:/purl.org/scimin-crm-mwf",
  "@type" : [ "http://www.w3.org/2002/07/owl#Ontology" ],
  "http://purl.org/dc/elements/1.1/title" : [ {
    "@value" : "Sustainable & Circular Production of Mineral Critical Raw Materials and Mining Waste Facility  (SCIMIN_CRM & MWF) Ontology"
  } ],
  "http://purl.org/dc/terms/contributor" : [ {
    "@value" : "Rajesh PIRYANI, Researcher AKKODIS Research\nSadeq ZOUGARI, Researcher AKKODIS Research"
  } ],
  "http://purl.org/dc/terms/creator" : [ {
    "@value" : "Rajesh PIRYANI, Researcher AKKODIS Research\nSadeq ZOUGARI, Researcher AKKODIS Research"
  } ],
  "http://purl.org/dc/terms/description" : [ {
    "@value" : "It is an ontology for Sustainable and Circular Production of Critical Mineral Raw Materials and Mining Waste Facilities. It aims to represent the key concepts and relationships involved in the life cycle of Mining Waste Facilities (MWFs). By capturing this life cycle—from exploration and exploitation to closure—the ontology enables decision support and reasoning within the SCIMIN-CRM platform."
  } ],
  "http://purl.org/dc/terms/license" : [ {
    "@value" : "This ontology is distributed under the Creative Commons Attribution 4.0 International License (CC BY 4.0).\n\nLicense URL:\n\nhttps://creativecommons.org/licenses/by/4.0/"
  } ],
  "http://www.w3.org/2002/07/owl#versionIRI" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/1.0"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/Activity",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "When the deposit is in operation"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/AirborneContaminant",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ],
  "http://www.w3.org/2000/01/rdf-schema#comment" : [ {
    "@value" : "Harmful substances suspended in the air, such as heavy metals or silica, that pose inhalation risk"
  } ],
  "http://www.w3.org/2000/01/rdf-schema#subClassOf" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/AirborneHazard"
  } ],
  "http://www.w3.org/2002/07/owl#disjointWith" : [ {
    "@id" : "http:/purl.org/scimin-crm-mwf/DustHazard"
  } ]
}, {
  "@id" : "http:/purl.org/scimin-crm-mwf/AirborneHazard",
  "@type" : [ "http://www.w3.org/2002/07/owl#Class" ]
