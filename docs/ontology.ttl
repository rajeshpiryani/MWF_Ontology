@prefix : <http:/purl.org/scimin-crm-mwf#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http:/purl.org/scimin-crm-mwf#> .

<http:/purl.org/scimin-crm-mwf> rdf:type owl:Ontology ;
                                 owl:versionIRI <http:/purl.org/scimin-crm-mwf/1.0> ;
                                 <http://purl.org/dc/elements/1.1/title> "Sustainable & Circular Production of Mineral Critical Raw Materials and Mining Waste Facility  (SCIMIN_CRM & MWF) Ontology" ;
                                 <http://purl.org/dc/terms/contributor> """Rajesh PIRYANI, Researcher AKKODIS Research
Sadeq ZOUGARI, Researcher AKKODIS Research""" ;
                                 <http://purl.org/dc/terms/creator> """Rajesh PIRYANI, Researcher AKKODIS Research
Sadeq ZOUGARI, Researcher AKKODIS Research""" ;
                                 <http://purl.org/dc/terms/description> "It is an ontology for Sustainable and Circular Production of Critical Mineral Raw Materials and Mining Waste Facilities. It aims to represent the key concepts and relationships involved in the life cycle of Mining Waste Facilities (MWFs). By capturing this life cycle—from exploration and exploitation to closure—the ontology enables decision support and reasoning within the SCIMIN-CRM platform." ;
                                 <http://purl.org/dc/terms/license> """This ontology is distributed under the Creative Commons Attribution 4.0 International License (CC BY 4.0).

License URL:

https://creativecommons.org/licenses/by/4.0/""" .

#################################################################
#    Annotation properties
#################################################################

###  http://purl.org/dc/elements/1.1/title
<http://purl.org/dc/elements/1.1/title> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/contributor
<http://purl.org/dc/terms/contributor> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/creator
<http://purl.org/dc/terms/creator> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/description
<http://purl.org/dc/terms/description> rdf:type owl:AnnotationProperty .


###  http://purl.org/dc/terms/license
<http://purl.org/dc/terms/license> rdf:type owl:AnnotationProperty .


#################################################################
#    Object Properties
#################################################################

###  http://www.w3.org/2002/07/owl#topObjectProperty
owl:topObjectProperty rdfs:domain <http:/purl.org/scimin-crm-mwf/ExcavationActivity> ;
                      rdfs:range <http:/purl.org/scimin-crm-mwf/AirborneHazard> .


###  http:/purl.org/scimin-crm-mwf/alternativeTo
<http:/purl.org/scimin-crm-mwf/alternativeTo> rdf:type owl:ObjectProperty ;
                                              rdfs:subPropertyOf owl:topObjectProperty ;
                                              rdf:type owl:IrreflexiveProperty ;
                                              rdfs:domain <http:/purl.org/scimin-crm-mwf/Reagent> ;
                                              rdfs:range <http:/purl.org/scimin-crm-mwf/Reagent> ;
                                              rdfs:comment "A safer or more sustainable substitute for a hazardous reagent used in industrial processes" .


###  http:/purl.org/scimin-crm-mwf/appliesTo
<http:/purl.org/scimin-crm-mwf/appliesTo> rdf:type owl:ObjectProperty ;
                                          rdfs:domain <http:/purl.org/scimin-crm-mwf/LCA> ;
                                          rdfs:range <http:/purl.org/scimin-crm-mwf/EnvironmentalImpact> .


###  http:/purl.org/scimin-crm-mwf/assess
<http:/purl.org/scimin-crm-mwf/assess> rdf:type owl:ObjectProperty ;
                                       rdfs:domain <http:/purl.org/scimin-crm-mwf/AssessmentMethod> ;
                                       rdfs:range <http:/purl.org/scimin-crm-mwf/Impact> .


###  http:/purl.org/scimin-crm-mwf/canCauseImpact
<http:/purl.org/scimin-crm-mwf/canCauseImpact> rdf:type owl:ObjectProperty ;
                                               rdfs:domain <http:/purl.org/scimin-crm-mwf/Risk> ;
                                               rdfs:range <http:/purl.org/scimin-crm-mwf/Impact> .


###  http:/purl.org/scimin-crm-mwf/containsHazardousSubstance
<http:/purl.org/scimin-crm-mwf/containsHazardousSubstance> rdf:type owl:ObjectProperty ;
                                                           rdfs:domain <http:/purl.org/scimin-crm-mwf/Material> ;
                                                           rdfs:range <http:/purl.org/scimin-crm-mwf/HazardousSubstance> .


###  http:/purl.org/scimin-crm-mwf/definedByRegulation
<http:/purl.org/scimin-crm-mwf/definedByRegulation> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <http:/purl.org/scimin-crm-mwf/MonitoringRequirement> ;
                                                    rdfs:range <http:/purl.org/scimin-crm-mwf/Regulation> .


###  http:/purl.org/scimin-crm-mwf/deliveredByCompetentAuthority
<http:/purl.org/scimin-crm-mwf/deliveredByCompetentAuthority> rdf:type owl:ObjectProperty ;
                                                              rdfs:domain <http:/purl.org/scimin-crm-mwf/Permit> ;
                                                              rdfs:range <http:/purl.org/scimin-crm-mwf/Authority> .


###  http:/purl.org/scimin-crm-mwf/generateResidualMaterial
<http:/purl.org/scimin-crm-mwf/generateResidualMaterial> rdf:type owl:ObjectProperty ;
                                                         rdfs:domain <http:/purl.org/scimin-crm-mwf/Material> ;
                                                         rdfs:range <http:/purl.org/scimin-crm-mwf/ResidualMaterial> ;
                                                         rdfs:comment "Waste material remaining after recovery processes, which may still contain hazardous substances" .


###  http:/purl.org/scimin-crm-mwf/hasActivity
<http:/purl.org/scimin-crm-mwf/hasActivity> rdf:type owl:ObjectProperty ;
                                            rdfs:domain <http:/purl.org/scimin-crm-mwf/MiningWasteFacility> ;
                                            rdfs:range <http:/purl.org/scimin-crm-mwf/Activity> .


###  http:/purl.org/scimin-crm-mwf/hasAirborneHazard
<http:/purl.org/scimin-crm-mwf/hasAirborneHazard> rdf:type owl:ObjectProperty ;
                                                  rdfs:domain <http:/purl.org/scimin-crm-mwf/ExcavationActivity> ;
                                                  rdfs:range <http:/purl.org/scimin-crm-mwf/AirborneHazard> .


###  http:/purl.org/scimin-crm-mwf/hasArea
<http:/purl.org/scimin-crm-mwf/hasArea> rdf:type owl:ObjectProperty ;
                                        rdfs:domain <http:/purl.org/scimin-crm-mwf/Mine> ,
                                                    <http:/purl.org/scimin-crm-mwf/MiningWasteFacility> ;
                                        rdfs:range <http:/purl.org/scimin-crm-mwf/Area> ;
                                        rdfs:comment "This term is analogus to structure of deposit/mine" .


###  http:/purl.org/scimin-crm-mwf/hasAssessmentMethod
<http:/purl.org/scimin-crm-mwf/hasAssessmentMethod> rdf:type owl:ObjectProperty ;
                                                    rdfs:domain <http:/purl.org/scimin-crm-mwf/Impact> ;
                                                    rdfs:range <http:/purl.org/scimin-crm-mwf/AssessmentMethod> .


