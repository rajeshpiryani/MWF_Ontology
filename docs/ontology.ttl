###  http:/purl.org/scimin-crm-mwf/AirborneContaminant
<http:/purl.org/scimin-crm-mwf/AirborneContaminant> rdf:type owl:Class ;
                                                    rdfs:subClassOf <http:/purl.org/scimin-crm-mwf/AirborneHazard> ;
                                                    owl:disjointWith <http:/purl.org/scimin-crm-mwf/DustHazard> ;
                                                    rdfs:comment "Harmful substances suspended in the air, such as heavy metals or silica, that pose inhalation risk" .


###  http:/purl.org/scimin-crm-mwf/AirborneHazard
<http:/purl.org/scimin-crm-mwf/AirborneHazard> rdf:type owl:Class .


###  http:/purl.org/scimin-crm-mwf/Area
<http:/purl.org/scimin-crm-mwf/Area> rdf:type owl:Class .


