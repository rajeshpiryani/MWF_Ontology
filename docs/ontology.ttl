#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( <http:/purl.org/scimin-crm-mwf/BiodiversityAssessmentGuideline>
                <http:/purl.org/scimin-crm-mwf/DesktopProximityGuideline>
                <http:/purl.org/scimin-crm-mwf/HabitatsManagementGuideline>
                <http:/purl.org/scimin-crm-mwf/SpeciesManagementGuideline>
              )
] .


[ rdf:type owl:AllDisjointClasses ;
  owl:members ( <http:/purl.org/scimin-crm-mwf/ChemicalAnalysisOperation>
                <http:/purl.org/scimin-crm-mwf/MineralogicalAnalysisOperation>
                <http:/purl.org/scimin-crm-mwf/PhysicalAndEnvironmentalTestingOperation>
                <http:/purl.org/scimin-crm-mwf/QualityAssuranceAndControlOperation>
                <http:/purl.org/scimin-crm-mwf/SamplingPreparationOperation>
