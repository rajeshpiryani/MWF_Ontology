<http:/purl.org/scimin-crm-mwf/hasCharacteristics> rdf:type owl:ObjectProperty ;
                                                   rdfs:domain <http:/purl.org/scimin-crm-mwf/MiningWasteFacility> ;
                                                   rdfs:range <http:/purl.org/scimin-crm-mwf/core:Characteristics> .


