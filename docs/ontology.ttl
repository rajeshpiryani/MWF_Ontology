                                                        rdfs:subClassOf <http:/purl.org/scimin-crm-mwf/MineralProcessingOperation> ;
                                                        rdfs:comment "Pyro processing includes the technologies for upgrading of the mineral fractions by drying, calcining or sintering."@en .


