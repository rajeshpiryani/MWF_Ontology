<http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/MineralogicalAnalysisOperation> rdf:type owl:Class ;
                                                                                                        rdfs:subClassOf <http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/LaboratoryAnalysisOperation> ;
                                                                                                        rdfs:comment "Determines the types and relative amounts of minerals within a material, providing insights into its composition, properties, and formation conditions" .


