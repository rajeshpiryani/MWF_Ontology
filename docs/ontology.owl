<?xml version="1.0"?>
<rdf:RDF xmlns="http:/purl.org/scimin-crm-mwf#"
     xml:base="http:/purl.org/scimin-crm-mwf"
     xmlns:dc="http://purl.org/dc/elements/1.1/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:terms="http://purl.org/dc/terms/">
    <owl:Ontology rdf:about="http:/purl.org/scimin-crm-mwf">
        <owl:versionIRI rdf:resource="http:/purl.org/scimin-crm-mwf/1.0"/>
        <dc:title>Sustainable &amp; Circular Production of Mineral Critical Raw Materials and Mining Waste Facility  (SCIMIN_CRM &amp; MWF) Ontology</dc:title>
        <terms:contributor>Rajesh PIRYANI, Researcher AKKODIS Research
Sadeq ZOUGARI, Researcher AKKODIS Research</terms:contributor>
        <terms:creator>Rajesh PIRYANI, Researcher AKKODIS Research
Sadeq ZOUGARI, Researcher AKKODIS Research</terms:creator>
        <terms:description>It is an ontology for Sustainable and Circular Production of Critical Mineral Raw Materials and Mining Waste Facilities. It aims to represent the key concepts and relationships involved in the life cycle of Mining Waste Facilities (MWFs). By capturing this life cycle—from exploration and exploitation to closure—the ontology enables decision support and reasoning within the SCIMIN-CRM platform.</terms:description>
        <terms:license>This ontology is distributed under the Creative Commons Attribution 4.0 International License (CC BY 4.0).

License URL:

https://creativecommons.org/licenses/by/4.0/</terms:license>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Annotation properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://purl.org/dc/elements/1.1/title -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/elements/1.1/title"/>
    


    <!-- http://purl.org/dc/terms/contributor -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/contributor"/>
    


    <!-- http://purl.org/dc/terms/creator -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/creator"/>
    


    <!-- http://purl.org/dc/terms/description -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/description"/>
    


    <!-- http://purl.org/dc/terms/license -->


    <owl:AnnotationProperty rdf:about="http://purl.org/dc/terms/license"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->


    


    <!-- http://www.w3.org/2002/07/owl#topObjectProperty -->


    <rdf:Description rdf:about="http://www.w3.org/2002/07/owl#topObjectProperty">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/ExcavationActivity"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/AirborneHazard"/>
    </rdf:Description>
    


    <!-- http:/purl.org/scimin-crm-mwf/alternativeTo -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/alternativeTo">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Reagent"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Reagent"/>
        <rdfs:comment>A safer or more sustainable substitute for a hazardous reagent used in industrial processes</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/appliesTo -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/appliesTo">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/LCA"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/EnvironmentalImpact"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/assess -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/assess">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/AssessmentMethod"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Impact"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/canCauseImpact -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/canCauseImpact">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Risk"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Impact"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/containsHazardousSubstance -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/containsHazardousSubstance">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Material"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/HazardousSubstance"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/definedByRegulation -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/definedByRegulation">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/MonitoringRequirement"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Regulation"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/deliveredByCompetentAuthority -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/deliveredByCompetentAuthority">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Permit"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Authority"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/generateResidualMaterial -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/generateResidualMaterial">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Material"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/ResidualMaterial"/>
        <rdfs:comment>Waste material remaining after recovery processes, which may still contain hazardous substances</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasActivity -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasActivity">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/MiningWasteFacility"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Activity"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasAirborneHazard -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasAirborneHazard">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/ExcavationActivity"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/AirborneHazard"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasArea -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasArea">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Mine"/>
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/MiningWasteFacility"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Area"/>
        <rdfs:comment>This term is analogus to structure of deposit/mine</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasAssessmentMethod -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasAssessmentMethod">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Impact"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/AssessmentMethod"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasAssessmentMetric -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasAssessmentMetric">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/AssessmentMethod"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Metric"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasCharacteristics -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasCharacteristics">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/MiningWasteFacility"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/core:Characteristics"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasCommunityEngagementStrategy -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasCommunityEngagementStrategy">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Activity"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/CommunityEngagementStrategy"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasControlMeasure -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasControlMeasure">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Activity"/>
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/AirborneHazard"/>
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/ResidualMaterial"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/ControlMeasure"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasEconomicEvaluation -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasEconomicEvaluation">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/MiningWasteFacility"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/EconomicEvaluationOperation"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasEmergencyProtocol -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasEmergencyProtocol">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/HazardousSubstance"/>
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Incident"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/EmergencyProtocol"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasEnvironmentalAndRiskAnalysis -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasEnvironmentalAndRiskAnalysis">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/MiningWasteFacility"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/EnvironmentalAndRiskAnalysisOperation"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasEnvironmentalImpact -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasEnvironmentalImpact">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/MiningWasteFacility"/>
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Operation"/>
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/ProcessingPlant"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/EnvironmentalImpact"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasEquipment -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasEquipment">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Operation"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Equipment"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasEvaluationParameter -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasEvaluationParameter">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Material"/>
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/SamplingPlan"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasExecutionofSamplingPlan -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasExecutionofSamplingPlan">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/SamplingPlan"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/ExecutionOfSamplingPlan"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasExploitationExtraction -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasExploitationExtraction">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/MiningWasteFacility"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/ExploitationExtraction"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasExplorationActivity -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasExplorationActivity">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Mine"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/ExplorationActivity"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasGeoDP -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasGeoDP">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/MiningWasteFacility"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/GeoreferencedDataPoints"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasGranulometry -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasGranulometry">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Material"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Granulometry"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasImpact -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasImpact">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/RestorationTechnique"/>
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Risk"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Impact"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasIncident -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasIncident">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Activity"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Incident"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasLCAInput -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasLCAInput">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/MiningLCA"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasLCARequirement -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasLCARequirement">
