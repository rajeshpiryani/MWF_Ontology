    <!-- http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/alternativeTo -->


    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/alternativeTo">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#IrreflexiveProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/Reagent"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/Reagent"/>
        <rdfs:comment>A safer or more sustainable substitute for a hazardous reagent used in industrial processes</rdfs:comment>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/appliesTo -->


