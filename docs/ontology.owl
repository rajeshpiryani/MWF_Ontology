        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Regulation"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasRemediationTechnique -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasRemediationTechnique"/>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasRestorationTechnique -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasRestorationTechnique">
