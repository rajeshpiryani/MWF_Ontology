    <!-- http:/purl.org/scimin-crm-mwf/Impact -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/Impact"/>
    


    <!-- http:/purl.org/scimin-crm-mwf/Incident -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/Incident">
        <rdfs:comment>Specific events involving hazardous substance release or exposure, including their nature and management</rdfs:comment>
    </owl:Class>
    


