        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Level"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasLocation -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasLocation">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Mine"/>
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Operation"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Location"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasMW -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasMW">
        <owl:inverseOf rdf:resource="http:/purl.org/scimin-crm-mwf/hasMWF"/>
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/MiningWasteFacility"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/MiningWaste"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasMWF -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasMWF">
