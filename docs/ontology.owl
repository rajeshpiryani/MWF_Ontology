        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/ProcessingPlant"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasRegulation -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasRegulation">
