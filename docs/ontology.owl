    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/BiodiversityAssessmentGuideline">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/Guidelines"/>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/BiodiversityAssessmentMethod -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/BiodiversityAssessmentMethod">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/AssessmentMethod"/>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/BiodiversityImpact -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/BiodiversityImpact">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/EnvironmentalImpact"/>
        <rdfs:comment>Any change caused by a proposed activity to species and habitats, ecosystems and landscapes</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/BlastingOperation -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/BlastingOperation">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/MineralProcessingOperation"/>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/ChemicalAnalysisOperation -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/ChemicalAnalysisOperation">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/LaboratoryAnalysisOperation"/>
        <rdfs:comment>process of determining the chemical composition of a substance using a range of methods and instruments to identify, characterize, and quantify its components</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/CommunityEngagementStrategy -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/CommunityEngagementStrategy"/>
    


    <!-- http:/purl.org/scimin-crm-mwf/CompactionOperation -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/CompactionOperation">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/MineralProcessingOperation"/>
        <rdfs:comment xml:lang="en">Compaction of minerals includes the technologies for moving and densifying minerals by vibration, impaction and pressure, mainly used in construction applications.

MWEI BREF : Process resulting in a reduction in volume. The change typically results from externally applied loads, creating tighter packing of the solid particles. In fine soils in particular, this requires an egress of pore water. Greater compaction often results in increased consolidation</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/ContainmentSystem -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/ContainmentSystem">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/ControlMeasure"/>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/ControlMeasure -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/ControlMeasure">
        <rdfs:comment>Techniques or technologies used to reduce exposure to hazardous substances, such as water sprays or enclosures</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/CountryLevel -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/CountryLevel">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/Level"/>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/Covers -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/Covers">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/ContainmentSystem"/>
        <owl:disjointWith rdf:resource="http:/purl.org/scimin-crm-mwf/Liners"/>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/CrushingAndScreeningOperation -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/CrushingAndScreeningOperation">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/MineralProcessingOperation"/>
        <rdfs:comment xml:lang="en">Crushing and screening is the first controlled size reduction stage in the process. This is the main process in aggregate  production and a preparation process for further size reduction.

MWEI BREF : Comminution process that reduces the particle size of ore to such a level that  grinding can be carried out. Usually, this is accomplished by compression of  ore against rigid surfaces, or by impact against surfaces in a rigidly constrained motion path.

MWEI BREF : Screening Separating material into size fractions.</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/CrushingMillingEquipment -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/CrushingMillingEquipment">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/Equipment"/>
        <rdfs:comment>What machinery/equipment is suitable to achieve desired particle size.</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/DesktopProximityGuideline -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/DesktopProximityGuideline">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/Guidelines"/>
        <rdfs:comment>Guideline defining the scope and purpose of a desktop proximity analysis, and how to use its output</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/DewateringOperation -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/DewateringOperation">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/MineralProcessingOperation"/>
        <rdfs:comment xml:lang="en">MWEI BREF : Process of removing water from an underground mine or open pit, or from the  surrounding rock or non-lithified area. The term is also commonly used for the reduction of water content in concentrates, extractive waste from mineral  processing and treatment sludge. In hydrocarbon extraction, dewatering may  refer to removing water from water-based drilling muds and cuttings.</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/DrillingOperation -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/DrillingOperation">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/MineralProcessingOperation"/>
        <rdfs:comment xml:lang="en">Drilling (and blasting) is the technology of achieving primary fragmentation of “in situ” minerals. This is the starting point for  most mineral processes with the exception of natural minerals in the form of sand and gravel.</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/DustEmission -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/DustEmission">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/EnvironmentalImpact"/>
    </owl:Class>
    


