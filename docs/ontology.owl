        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/MineralProcessingOperation"/>
        <rdfs:comment xml:lang="en">MWEI BREF : Process of reducing ore into smaller fragments to prepare it for further  processing and/or so that it can be transported to the processing plant. In 
underground mines, the primary crusher is often located underground or at the 
entrance to the processing plant.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/Procedure -->


