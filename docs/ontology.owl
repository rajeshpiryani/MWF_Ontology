    <!-- http:/purl.org/scimin-crm-mwf/Material -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/Material">
        <rdfs:comment>INSPIRE: EarthMaterial is an abstract class which holds a description of a naturally occurring substance in the Earth. Earth Material represents material composition or substance, and is thus independent of quantity or location.</rdfs:comment>
    </owl:Class>
    


