    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/Methodology"/>
    


    <!-- http:/purl.org/scimin-crm-mwf/Metric -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/Metric">
        <rdfs:comment>Metrics that translate collected data into representative information that can be used in decision-making</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/MicroscopicCharacteristics -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/MicroscopicCharacteristics">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/core:Characteristics"/>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/MillingOperation -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/MillingOperation">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/MineralProcessingOperation"/>
        <rdfs:comment xml:lang="en">MWEI BREF : Operation during which ore is treated for the recovery and/or concentration of valuable minerals prior to shipment to a smelter or refinery. Milling
processes include crushing, grinding, screening, concentration and dewatering. At a coal mine, the mill is referred to as a wash plant, tipple or cleaner</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/Mine -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/Mine">
        <rdfs:comment xml:lang="en">MWEI BREF : Area under the control of an operator where mining occurs (see &quot;mining&quot;), including common related infrastructure and waste management activities.

INSPIRE: An excavation carried out for the extraction of mineral deposits.</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/Mineral -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/Mineral">
        <rdfs:comment xml:lang="en">Mineral is a natural inorganic substance precisely defined  according to its physical and chemical characteristics.

INSPIRE: Mineral is defined as any naturally occurring inorganic element or compound having a periodically repeating arrangement of atoms and a characteristic chemical composition or range of compositions, resulting in distinctive physical properties.</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/MineralMeasurement -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/MineralMeasurement">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/Measurement"/>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/MineralProcessingOperation -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/MineralProcessingOperation">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/Operation"/>
        <rdfs:comment xml:lang="en">MWEI BREF : Mineral processing (also beneficiation or benefication, ore dressing, mineral dressing, milling) 
Processes to produce marketable mineral products (e.g. concentrates) from mineral resources. This is usually carried out on the mine or quarry site, the plant being referred to as the mineral processing plant (mill or concentrator). .The essential purpose is to reduce the bulk of the ore, which must be transported to and processed by subsequent processes (e.g. smelting), by using methods to separate the valuable (desired) mineral(s) from the gangue. 
The marketable product of this is called concentrate, the remaining material is called extractive waste from mineral processing (e.g. tailings).
Mineral processing includes various procedures that rely on the mineral&apos;s physical characteristics (i.e. particle size, density, magnetic properties, colour) or physico-chemical properties (surface tension, hydrophobicity, wettability).</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/MineralogicalAnalysis -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/MineralogicalAnalysis"/>
    


    <!-- http:/purl.org/scimin-crm-mwf/MineralogicalAnalysisOperation -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/MineralogicalAnalysisOperation">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/LaboratoryAnalysisOperation"/>
        <rdfs:comment>Determines the types and relative amounts of minerals within a material, providing insights into its composition, properties, and formation conditions</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/MineralogicalCharacteristics -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/MineralogicalCharacteristics">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/core:Characteristics"/>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/MiningLCA -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/MiningLCA">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/LCA"/>
        <rdfs:comment>LCA in mining is a systematic method for identifying, quantifying, and evaluating the environmental impacts associated with the entire life cycle of mining-related processes and products, from exploration and extraction to processing, transportation, use, and end-of-life management.</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/MiningWaste -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/MiningWaste">
        <rdfs:comment xml:lang="en">MWEI BREF : Waste resulting from the prospecting, extraction, treatment and storage of mineral resources and the working of quarries.

Mining activity exploits a mineral deposit, obtaining a concentrate (mineral object of the activity) and waste.</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/MiningWasteFacility -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/MiningWasteFacility">
        <rdfs:comment xml:lang="en">A mining waste facility is a designated site or structure used to store extractive waste (includes materials like waste rock and tailings from mining and mineral processing operations).

MWEI BREF : Any area under the responsibility of an operator where extractive waste is  handled, treated, accumulated or deposited whether in a solid or liquid state or  in solution or suspension. This includes, but is not limited to, Extractive 
Waste Facilities, excavation voids where extractive waste is placed back, and  areas for temporary storage of extractive waste.

Mining Waste (INSPIRE Model)
Mining waste can be defined as a part of the materials that result from the exploration, mining and processing of substances governed by legislation on mines and quarries.</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/MiningWasteMeasurement -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/MiningWasteMeasurement">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/Measurement"/>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/MitigationEnvironmentalImpactProcedure -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/MitigationEnvironmentalImpactProcedure">
