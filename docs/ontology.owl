        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Metal"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasMethodology -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasMethodology">
