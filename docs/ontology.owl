        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Material"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasMetal -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasMetal">
