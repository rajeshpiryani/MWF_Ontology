        <dc:title>Mining Waste Facility (MWF) Ontology</dc:title>
        <terms:contributor></terms:contributor>
        <terms:creator>Rajesh PIRYANI, Researcher AKKODIS Research</terms:creator>
        <terms:description>An ontology for Mining Waste Facilities.</terms:description>
        <terms:license></terms:license>
    </owl:Ontology>
    


