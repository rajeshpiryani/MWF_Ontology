        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/MineralProcessingOperation"/>
        <rdfs:comment xml:lang="en">Grinding is the stage of size reduction (wet or dry) where the liberation size for individual minerals can be reached. By further size reduction filler (mineral powder) is produced.</rdfs:comment>
    </owl:Class>
    


