        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Methodology"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasMineral -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasMineral">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Material"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Mineral"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasNACECode -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasNACECode">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/EconomicActivity"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/NACECode"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasOperation -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasOperation">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/Activity"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/Operation"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasProcessingPlant -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasProcessingPlant">
