    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasLaboratoryAnalysis -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasLaboratoryAnalysis">
        <rdfs:domain rdf:resource="http:/purl.org/scimin-crm-mwf/SamplingPlan"/>
        <rdfs:range rdf:resource="http:/purl.org/scimin-crm-mwf/LaboratoryAnalysisOperation"/>
    </owl:ObjectProperty>
    


    <!-- http:/purl.org/scimin-crm-mwf/hasLevel -->


    <owl:ObjectProperty rdf:about="http:/purl.org/scimin-crm-mwf/hasLevel">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
