    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/EnvironmentalRisk -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/EnvironmentalRisk">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/Risk"/>
        <rdfs:comment>Potential harm to the environment caused by hazardous substances or activities</rdfs:comment>
    </owl:Class>
    


