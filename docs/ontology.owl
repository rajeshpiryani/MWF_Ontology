    <owl:Class rdf:about="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/ChemicalAnalysisOperation">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/LaboratoryAnalysisOperation"/>
        <rdfs:comment>process of determining the chemical composition of a substance using a range of methods and instruments to identify, characterize, and quantify its components</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/CommunityEngagementStrategy -->


    <owl:Class rdf:about="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/CommunityEngagementStrategy"/>
    


    <!-- http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/CompactionOperation -->


    <owl:Class rdf:about="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/CompactionOperation">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/MineralProcessingOperation"/>
        <rdfs:comment xml:lang="en">METSO Handbook : Compaction of minerals includes the technologies for moving and densifying minerals by vibration, impaction and pressure, 
mainly used in construction applications</rdfs:comment>
        <rdfs:comment xml:lang="en">MWEI BREF : Process resulting in a reduction in volume. The change typically results from externally applied loads, creating tighter packing of the solid particles. In fine soils in particular, this requires an egress of pore water. Greater compaction 
often results in increased consolidation</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/ContainmentSystem -->


    <owl:Class rdf:about="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/ContainmentSystem">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/ControlMeasure"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/ControlMeasure -->


    <owl:Class rdf:about="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/ControlMeasure">
        <rdfs:comment>Techniques or technologies used to reduce exposure to hazardous substances, such as water sprays or enclosures</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/CountryLevel -->


    <owl:Class rdf:about="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/CountryLevel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/Level"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/Covers -->


    <owl:Class rdf:about="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/Covers">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/ContainmentSystem"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/Liners"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/CrushingAndScreeningOperation -->


    <owl:Class rdf:about="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/CrushingAndScreeningOperation">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/MineralProcessingOperation"/>
        <rdfs:comment xml:lang="en">METSO Handbook : Crushing and screening is the first controlled size reduction stage in the process. This is the main process in aggregate  production and a preparation process for further size reduction.</rdfs:comment>
        <rdfs:comment xml:lang="en">MWEI BREF : Comminution process that reduces the particle size of ore to such a level that  grinding can be carried out. Usually, this is accomplished by compression of  ore against rigid surfaces, or by impact against surfaces in a rigidly constrained motion path.</rdfs:comment>
        <rdfs:isDefinedBy xml:lang="en">MWEI BREF : Screening Separating material into size fractions.</rdfs:isDefinedBy>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/DesktopProximityGuideline -->


    <owl:Class rdf:about="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/DesktopProximityGuideline">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/Guidelines"/>
        <rdfs:comment>Guideline defining the scope and purpose of a desktop proximity analysis, and how to use its output</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/DewateringOperation -->


    <owl:Class rdf:about="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/DewateringOperation">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/MineralProcessingOperation"/>
        <rdfs:comment xml:lang="en">MWEI BREF : Process of removing water from an underground mine or open pit, or from the  surrounding rock or non-lithified area. The term is also commonly used for the reduction of water content in concentrates, extractive waste from mineral  processing and treatment sludge. In hydrocarbon extraction, dewatering may  refer to removing water from water-based drilling muds and cuttings.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/DrillingOperation -->


    <owl:Class rdf:about="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/DrillingOperation">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/MineralProcessingOperation"/>
        <rdfs:comment xml:lang="en">METSO Handbook : Drilling (and blasting) is the technology of achieving primary fragmentation of “in situ” minerals. This is the starting point for  most mineral processes with the exception of natural minerals in the form of sand and gravel.</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/DustEmission -->


