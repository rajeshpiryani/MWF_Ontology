        <rdfs:comment>Guideline defining how to decide on management measures that create the best possible positive outcome for species presence and reducing extinction risk</rdfs:comment>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/StandardizedProtocols -->


    <owl:Class rdf:about="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/StandardizedProtocols">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/rajesh.piryani/ontologies/2025/3/SCIMIN_CRM/ExecutionOfSamplingPlan"/>
        <rdfs:comment>MINNERSA, SGS
