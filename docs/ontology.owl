    <!-- http:/purl.org/scimin-crm-mwf/PrimaryCrushingOperation -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/PrimaryCrushingOperation">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/MineralProcessingOperation"/>
        <rdfs:comment xml:lang="en">MWEI BREF : Process of reducing ore into smaller fragments to prepare it for further  processing and/or so that it can be transported to the processing plant. In 
underground mines, the primary crusher is often located underground or at the 
entrance to the processing plant.</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/Procedure -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/Procedure"/>
    


