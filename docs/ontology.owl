        <rdfs:comment xml:lang="en">Materials handling includes the technologies for moving the process flow (dry) forward by loading, transportation, storage  and feeding</rdfs:comment>
    </owl:Class>
    


    <!-- http:/purl.org/scimin-crm-mwf/MaterialMeasurement -->


    <owl:Class rdf:about="http:/purl.org/scimin-crm-mwf/MaterialMeasurement">
        <rdfs:subClassOf rdf:resource="http:/purl.org/scimin-crm-mwf/Measurement"/>
    </owl:Class>
    


